{
  "name": "valma-inventario",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Sistema de inventario y contabilidad comercial",
  "scripts": {
    "postinstall": "npm install --prefix backend && npm install --prefix frontend",
    "start": "concurrently -n api,web -c blue,green \"npm start --prefix backend\" \"npm start --prefix frontend\"",
    "dev": "npm start",
    "build": "npm run build --prefix frontend",
    "db:init": "npm run db:init --prefix backend",
    "db:seed": "npm run db:seed --prefix backend",
    "db:migrate": "npm run db:migrate --prefix backend",
    "db:setup": "npm run db:setup --prefix backend"
  },
  "dependencies": {
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
