PORT=3001

# Neon PostgreSQL
DATABASE_URL=postgresql://usuario:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_SSL=true

# Cloudinary — imágenes de productos
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Administrador único
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia_esta_contraseña
JWT_SECRET=clave_secreta_larga_y_aleatoria
JWT_EXPIRES_IN=24h

UPLOAD_DIR=uploads
CORS_ORIGIN=http://localhost:5173
